---
import '../styles/global.css';
const { title = 'Sistema Inteligente de Monitoreo de Parámetros Eléctricos — CECAR' } =
  Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Portafolio académico — sistema inteligente de monitoreo de parámetros eléctricos en bloques universitarios de CECAR. Contenido ilustrativo."
    />
    <title>{title}</title>
    <script is:inline>
      // Aplica el tema antes de pintar para evitar parpadeo (FOUC).
      const t =
        localStorage.getItem('theme') ??
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (t === 'dark') document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="antialiased">
    <button
      id="theme-toggle"
      type="button"
      aria-label="Cambiar tema claro / oscuro"
      class="fixed right-4 top-4 z-50 inline-flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface/80 text-ink shadow-soft backdrop-blur transition hover:border-indigo hover:text-indigo"
    >
      <svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
      </svg>
      <svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" />
      </svg>
    </button>

    <slot />

    <script>
      // Toggle de tema, persistido en localStorage.
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const dark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      });

      // Reveal al entrar en viewport + escalonado por hijos con [data-stagger].
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
      );
      document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
        const group = el.closest('[data-stagger]');
        if (group) {
          const siblings = [...group.querySelectorAll('.reveal')];
          el.style.setProperty('--reveal-delay', `${siblings.indexOf(el) * 90}ms`);
        }
        io.observe(el);
      });

      // Contadores animados: <span data-count="168" data-suffix=" h" data-prefix="λ = ">
      const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
      const countIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            const el = e.target as HTMLElement;
            const target = Number(el.dataset.count);
            const pre = el.dataset.prefix ?? '';
            const suf = el.dataset.suffix ?? '';
            const dur = 1200;
            const start = performance.now();
            const tick = (now: number) => {
              const p = Math.min(1, (now - start) / dur);
              el.textContent = pre + Math.round(easeOut(p) * target) + suf;
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            countIO.unobserve(el);
          }
        },
        { threshold: 0.6 },
      );
      document.querySelectorAll('[data-count]').forEach((el) => countIO.observe(el));
    </script>
  </body>
</html>
