---
import '../styles/global.css';
import { t } from '../i18n';
const locale = Astro.currentLocale ?? 'en';
const L = t(locale).meta;
const otherHref = locale === 'es' ? '/' : '/es'; // sólo existe index por idioma
const { title = L.title } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={L.description} />
    <title>{title}</title>
    <script is:inline>
      // Aplica el tema antes de pintar para evitar parpadeo (FOUC).
      const t =
        localStorage.getItem('theme') ??
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (t === 'dark') document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="antialiased">
    <div class="fixed right-4 top-4 z-50 flex items-center gap-2">
    <a
      href={otherHref}
      aria-label={L.langAria}
      class="mono inline-flex h-10 items-center gap-1.5 rounded-md border border-line bg-surface px-3 text-[11px] font-medium uppercase tracking-widest text-muted shadow-soft transition hover:border-signal hover:text-signal"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" />
      </svg>
      {L.langLabel}
    </a>
    <button
      id="theme-toggle"
      type="button"
      aria-label={L.themeAria}
      class="mono inline-flex h-10 items-center gap-2 rounded-md border border-line bg-surface px-3 text-[11px] font-medium uppercase tracking-widest text-muted shadow-soft transition hover:border-signal hover:text-signal"
    >
      <svg class="h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
      </svg>
      <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" />
      </svg>
      <span class="dark:hidden">Light</span>
      <span class="hidden dark:inline">Dark</span>
    </button>
    </div>

    <slot />

    <script>
      // Toggle de tema, persistido en localStorage.
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const dark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', dark ? 'dark' : 'light');
        // Avisa a los charts/canvas para que relean sus colores del tema.
        window.dispatchEvent(new CustomEvent('themechange', { detail: { dark } }));
      });

      // Reveal al entrar en viewport + escalonado por hijos con [data-stagger].
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
      );
      document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
        const group = el.closest('[data-stagger]');
        if (group) {
          const siblings = [...group.querySelectorAll('.reveal')];
          el.style.setProperty('--reveal-delay', `${siblings.indexOf(el) * 90}ms`);
        }
        io.observe(el);
      });

      // Contadores animados: <span data-count="168" data-suffix=" h" data-prefix="λ = ">
      const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
      const countIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            const el = e.target as HTMLElement;
            const target = Number(el.dataset.count);
            const pre = el.dataset.prefix ?? '';
            const suf = el.dataset.suffix ?? '';
            const dur = 1200;
            const start = performance.now();
            const tick = (now: number) => {
              const p = Math.min(1, (now - start) / dur);
              el.textContent = pre + Math.round(easeOut(p) * target) + suf;
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            countIO.unobserve(el);
          }
        },
        { threshold: 0.6 },
      );
      document.querySelectorAll('[data-count]').forEach((el) => countIO.observe(el));
    </script>
  </body>
</html>
