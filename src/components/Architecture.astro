---
const nodes = [
  {
    name: 'Sensores (CT / Bobinas Rogowski)',
    desc: 'Captura analógica de corriente en la línea eléctrica',
    icon: 'M3 12h3l2-7 4 14 2-7h3',
  },
  {
    name: 'ADE9000 (Analog Devices)',
    desc: 'Front-end analógico de alta precisión — Clase 0.2, 7 ADCs internos',
    icon: 'M4 4h16v16H4z M9 4v16 M15 4v16',
  },
  {
    name: 'Microcontrolador',
    desc: 'Empaqueta y transmite datos digitalizados vía SPI',
    icon: 'M7 7h10v10H7z M2 10h2 M2 14h2 M20 10h2 M20 14h2 M10 2v2 M14 2v2 M10 20v2 M14 20v2',
  },
  {
    name: 'WiFi / UTP',
    desc: 'Canal de transmisión hacia el servidor de procesamiento',
    icon: 'M5 12a10 10 0 0 1 14 0 M8.5 15.5a5 5 0 0 1 7 0 M12 19h.01',
  },
  {
    name: 'Vatio Laboratory',
    desc: 'Servidor central de almacenamiento y procesamiento',
    icon: 'M4 5h16v6H4z M4 13h16v6H4z M8 8h.01 M8 16h.01',
  },
  {
    name: 'Motor de Suavizado',
    desc: 'Filtros Kalman, Savitzky-Golay y Whittaker',
    icon: 'M3 17c3 0 3-10 6-10s3 10 6 10 3-7 6-7',
  },
  {
    name: 'Modelo Predictivo (LSTM)',
    desc: 'Red neuronal recurrente de 7 capas para predicción energética',
    icon: 'M5 6a2 2 0 1 0 0-.01 M5 18a2 2 0 1 0 0-.01 M19 12a2 2 0 1 0 0-.01 M7 7l10 4 M7 17l10-4',
  },
  {
    name: 'Visualización',
    desc: 'Dashboard web interactivo (Next.js + React)',
    icon: 'M3 4h18v12H3z M8 20h8 M12 16v4',
  },
];
---

<section id="arquitectura" class="relative border-b border-line bg-canvas-2">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <p class="reveal kicker">Cómo funciona</p>
    <h2 class="reveal mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
      Arquitectura del sistema
    </h2>
    <p class="reveal mt-4 max-w-3xl text-lg text-muted">
      Cada vatio recorre un camino. Desde la pinza que abraza el conductor hasta la
      gráfica que aparece en pantalla, el dato atraviesa ocho etapas de adquisición,
      transmisión, depuración y predicción. Nada se mide dos veces; todo se transforma una
      vez bien.
    </p>

    <div class="mt-14 flex flex-wrap items-stretch gap-3" data-stagger>
      {
        nodes.map((n, i) => (
          <>
            <div class="reveal card-lift group flex w-full flex-1 basis-[220px] flex-col rounded-xl border border-line bg-surface p-4 shadow-soft">
              <span class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-soft text-indigo transition group-hover:scale-110 group-hover:bg-indigo group-hover:text-white">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-5 w-5"
                >
                  <path d={n.icon} />
                </svg>
              </span>
              <p class="text-sm font-semibold leading-snug text-ink">{n.name}</p>
              <p class="mt-1 text-xs leading-relaxed text-muted">{n.desc}</p>
              <span class="mt-3 text-[10px] font-semibold uppercase tracking-wider text-indigo/60">
                Etapa {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            {i < nodes.length - 1 && (
              <div class="hidden items-center self-center sm:flex" aria-hidden="true">
                <svg width="28" height="16" viewBox="0 0 28 16" fill="none">
                  <line x1="2" y1="8" x2="22" y2="8" stroke="#4f46e5" stroke-width="2" class="flow-line" />
                  <path d="M20 4l5 4-5 4" stroke="#4f46e5" stroke-width="2" fill="none" />
                </svg>
              </div>
            )}
          </>
        ))
      }
    </div>

    <!-- Figura opcional: transición de datos / capas IoT. Suelta el archivo y aparece. -->
    <figure class="reveal mt-14 overflow-hidden rounded-2xl border border-line bg-surface shadow-soft">
      <img
        src="/images/transicion-datos.png"
        alt="Diagrama de la transición de datos del sistema IoT"
        class="block w-full"
        loading="lazy"
        onerror="this.closest('figure').remove()"
      />
      <figcaption class="border-t border-line px-4 py-3 text-sm text-muted">
        Transición de datos a través de las capas del sistema IoT — del sensor al servidor.
      </figcaption>
    </figure>
  </div>
</section>
