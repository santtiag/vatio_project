---
import { t } from '../i18n';
const L = t(Astro.currentLocale).methodology;
const pasos = L.pasos;
---

<section id="metodologia" class="relative border-b border-line bg-canvas-2">
  <div class="mx-auto max-w-4xl px-6 py-24">
    <p class="reveal kicker">Measurement Log</p>
    <h2 class="reveal mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{L.h2}</h2>
    <p class="reveal mt-4 text-lg text-muted">
      {L.intro}
    </p>

    <ol class="mt-14" data-stagger>
      {
        pasos.map((p, i) => (
          <li class="reveal relative flex gap-5 border-l border-line pb-8 pl-0 last:border-l-transparent last:pb-0">
            <span class="mono z-10 -ml-px flex h-10 w-10 flex-none items-center justify-center border border-line bg-surface text-sm font-medium tabular-nums text-signal shadow-soft">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="pt-1.5">
              <p class="mono text-[10px] uppercase tracking-widest text-muted">{L.stageWord} {String(i + 1).padStart(2, '0')} / 06</p>
              <h3 class="mt-0.5 font-semibold text-ink">{p.t}</h3>
              <p class="mt-1 text-sm leading-relaxed text-muted">{p.d}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
