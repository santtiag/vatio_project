---
import { t } from '../i18n';
const L = t(Astro.currentLocale).smoothing;
// Datos no traducibles (ecuaciones, parámetros, cuál es el mejor) por índice.
const structural = [
  {
    exprs: [
      'x̂ₖ⁻ = x̂ₖ₋₁ ,    Pₖ⁻ = Pₖ₋₁ + Q',
      'Kₖ = Pₖ⁻ / (Pₖ⁻ + R)',
      'x̂ₖ = x̂ₖ⁻ + Kₖ (zₖ − x̂ₖ⁻)',
      'Pₖ = (1 − Kₖ) Pₖ⁻',
    ],
    params: ['Q = process_variance = 0.1', 'R = measurement_variance = 10', 'P₀ = initial_error = 1.0'],
    best: false,
  },
  {
    exprs: [
      'ŷᵢ = Σⱼ cⱼ · yᵢ₊ⱼ ,   j = −m … m,   2m+1 = 31',
      'C = (Aᵀ A)⁻¹ Aᵀ ,   Aᵢⱼ = jⁱ',
      'A ∈ Vandermonde,   grado p = 2',
    ],
    params: ['window_length = 31', 'polyorder = 2'],
    best: false,
  },
  {
    exprs: [
      'Q(z) = ‖y − z‖² + λ ‖Dᵈ z‖²',
      'z = (I + λ Dᵈᵀ Dᵈ)⁻¹ y',
      'GCV(λ) = n‖y − z‖² / (n − tr H)² ,  H = (I + λ DᵀD)⁻¹',
    ],
    params: ['λ = 10', 'd = 2', 'GCV = 11.1403  (mínimo)'],
    best: true,
  },
];
const algos = L.algos.map((a, i) => ({
  nombre: a.nombre,
  intuicion: a.intuicion,
  nota: a.nota,
  best: structural[i].best,
  params: structural[i].params,
  eqs: a.eqLabels.map((label, j) => ({ label, expr: structural[i].exprs[j] })),
}));
---

<section id="suavizado" class="relative border-b border-line bg-canvas-2">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <p class="reveal kicker">Signal Conditioning</p>
    <h2 class="reveal mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
      {L.h2}
    </h2>
    <p class="reveal mt-4 max-w-3xl text-lg text-muted" set:html={L.intro} />

    <div class="mt-14 grid gap-6 lg:grid-cols-3" data-stagger>
      {
        algos.map((a) => (
          <div
            class={`reveal card-lift instrument relative flex flex-col p-6 shadow-soft ${a.best ? 'border-signal ring-1 ring-signal' : ''}`}
          >
            {a.best && (
              <span class="mono absolute -top-3 right-5 rounded border border-signal bg-signal px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-canvas shadow-soft">
                {L.bestBadge}
              </span>
            )}
            <h3 class="text-lg font-semibold">{a.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{a.intuicion}</p>

            <div class="mt-4 space-y-2">
              {a.eqs.map((e) => (
                <div class="rounded border-l-2 border-signal bg-surface-2 px-3 py-2">
                  <span class="mono block text-[10px] font-medium uppercase tracking-widest text-signal">
                    {e.label}
                  </span>
                  <code class="mt-0.5 block font-mono text-sm leading-relaxed text-ink">
                    {e.expr}
                  </code>
                </div>
              ))}
            </div>

            <ul class="mt-4 flex flex-wrap gap-1.5">
              {a.params.map((p) => (
                <li class="rounded border border-line bg-signal-soft px-2 py-1 font-mono text-xs text-signal">{p}</li>
              ))}
            </ul>

            <p class="mt-auto pt-4 text-xs leading-relaxed text-soft">{a.nota}</p>
          </div>
        ))
      }
    </div>

    <div class="reveal scanline mt-14 instrument p-6 shadow-soft">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <h3 class="font-semibold">{L.chartTitle}</h3>
        <span class="mono rounded border border-line bg-surface-2 px-2 py-0.5 text-[11px] uppercase tracking-wider text-muted">
          {L.illustrativeScale}
        </span>
      </div>
      <canvas id="chart-smoothing" height="120"></canvas>
    </div>
  </div>
</section>

<script>
  import Chart from 'chart.js/auto';
  import { noisySignal, kalman1D, smooth } from '../lib/signals';
  import { themeColors, onThemeChange } from '../lib/theme';

  const N = 90;
  const raw = noisySignal(N, 21);
  const kal = kalman1D(raw);
  const sav = smooth(raw, 4);
  const whit = smooth(raw, 8);
  const labels = Array.from({ length: N }, (_, i) => i); // minutos
  const el = document.getElementById('chart-smoothing') as HTMLCanvasElement;
  // Etiquetas del chart según el idioma de la página (no se reanima al traducir).
  const es = document.documentElement.lang === 'es';
  const txt = {
    raw: es ? 'Señal original (ruidosa)' : 'Original signal (noisy)',
    whittaker: es ? 'Whittaker (λ=10)' : 'Whittaker (λ=10)',
    xAxis: es ? 'Tiempo (minutos)' : 'Time (minutes)',
    yAxis: es ? 'Corriente (A)' : 'Current (A)',
  };
  let chart: Chart | null = null;

  function build(animate = true) {
    const c = themeColors();
    Chart.defaults.color = c.muted;
    Chart.defaults.borderColor = c.gridLine;
    chart?.destroy();
    chart = new Chart(el, {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: txt.raw, data: raw, borderColor: c.amber + '88', borderWidth: 1, pointRadius: 0, tension: 0 },
          { label: 'Kalman', data: kal, borderColor: c.muted, borderWidth: 1.5, pointRadius: 0, tension: 0.2 },
          { label: 'Savitzky-Golay', data: sav, borderColor: c.amber, borderWidth: 1.5, pointRadius: 0, tension: 0.2 },
          { label: txt.whittaker, data: whit, borderColor: c.signal, borderWidth: 3, pointRadius: 0, tension: 0.3 },
        ],
      },
      options: {
        responsive: true,
        interaction: { mode: 'index', intersect: false },
        animation: animate ? { duration: 1800, easing: 'easeInOutQuart' } : false,
        animations: animate ? { y: { from: (ctx: any) => (ctx.chart.scales.y.getPixelForValue(20)) } } : {},
        transitions: { show: { animation: { duration: 1800 } } },
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 14, usePointStyle: true } } },
        scales: {
          x: { title: { display: true, text: txt.xAxis }, ticks: { maxTicksLimit: 10 }, grid: { display: false } },
          y: { title: { display: true, text: txt.yAxis } },
        },
      },
    });
  }

  // Arranca la animación cuando el chart entra en pantalla.
  const io = new IntersectionObserver((es) => {
    for (const e of es) if (e.isIntersecting) { build(); io.disconnect(); }
  }, { threshold: 0.3 });
  io.observe(el);

  // Recolorea al alternar tema (sin re-animar).
  onThemeChange(() => { if (chart) build(false); });
</script>
