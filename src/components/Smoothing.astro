---
const algos = [
  {
    nombre: 'Filtro de Kalman',
    intuicion: 'Estimación bayesiana recursiva: predice, mide y corrige en cada paso.',
    eqs: [
      { label: 'Predicción', expr: 'x̂ₖ⁻ = x̂ₖ₋₁ ,    Pₖ⁻ = Pₖ₋₁ + Q' },
      { label: 'Ganancia', expr: 'Kₖ = Pₖ⁻ / (Pₖ⁻ + R)' },
      { label: 'Corrección', expr: 'x̂ₖ = x̂ₖ⁻ + Kₖ (zₖ − x̂ₖ⁻)' },
      { label: 'Covarianza', expr: 'Pₖ = (1 − Kₖ) Pₖ⁻' },
    ],
    params: ['Q = process_variance = 0.1', 'R = measurement_variance = 10', 'P₀ = initial_error = 1.0'],
    nota: 'Cuanto mayor es R frente a Q, más confía el filtro en su predicción y menos en la medición ruidosa.',
    best: false,
  },
  {
    nombre: 'Savitzky-Golay',
    intuicion: 'Ajusta un polinomio local por mínimos cuadrados y evalúa su centro: suaviza sin aplanar los picos.',
    eqs: [
      { label: 'Convolución', expr: 'ŷᵢ = Σⱼ cⱼ · yᵢ₊ⱼ ,   j = −m … m,   2m+1 = 31' },
      { label: 'Coeficientes', expr: 'C = (Aᵀ A)⁻¹ Aᵀ ,   Aᵢⱼ = jⁱ' },
      { label: 'Ventana', expr: 'A ∈ Vandermonde,   grado p = 2' },
    ],
    params: ['window_length = 31', 'polyorder = 2'],
    nota: 'A es la matriz de Vandermonde de la ventana; la fila central de C da los pesos de suavizado.',
    best: false,
  },
  {
    nombre: 'Whittaker',
    intuicion: 'Equilibra fidelidad al dato y suavidad penalizando la d-ésima derivada de la señal estimada.',
    eqs: [
      { label: 'Funcional', expr: 'Q(z) = ‖y − z‖² + λ ‖Dᵈ z‖²' },
      { label: 'Solución', expr: 'z = (I + λ Dᵈᵀ Dᵈ)⁻¹ y' },
      { label: 'Selección (GCV)', expr: 'GCV(λ) = n‖y − z‖² / (n − tr H)² ,  H = (I + λ DᵀD)⁻¹' },
    ],
    params: ['λ = 10', 'd = 2', 'GCV = 11.1403  (mínimo)'],
    nota: 'λ se elige minimizando GCV — sin ground truth. Dᵈ es la matriz de diferencias de orden d.',
    best: true,
  },
];
---

<section id="suavizado" class="relative border-b border-line bg-canvas-2">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <p class="reveal kicker">Depuración de la señal</p>
    <h2 class="reveal mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
      Algoritmos de suavizado
    </h2>
    <p class="reveal mt-4 max-w-3xl text-lg text-muted">
      Toda medición eléctrica llega con ruido. Antes de predecir, hay que decidir cómo
      limpiarla — y hacerlo <strong class="font-semibold text-ink">sin conocer la verdad de
      fondo</strong>. Se comparan tres formulaciones clásicas y se selecciona la mejor por
      validación cruzada generalizada (GCV), un criterio que no necesita ground truth.
    </p>

    <div class="mt-14 grid gap-6 lg:grid-cols-3" data-stagger>
      {
        algos.map((a) => (
          <div
            class={`reveal card-lift relative flex flex-col rounded-2xl border bg-surface p-6 shadow-soft ${a.best ? 'border-indigo ring-1 ring-indigo' : 'border-line'}`}
          >
            {a.best && (
              <span class="absolute -top-3 right-5 rounded-full bg-gradient-to-r from-indigo to-violet-600 px-3 py-1 text-xs font-semibold text-white shadow-soft">
                ★ Mejor GCV
              </span>
            )}
            <h3 class="text-lg font-semibold">{a.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{a.intuicion}</p>

            <div class="mt-4 space-y-2">
              {a.eqs.map((e) => (
                <div class="rounded-lg border-l-2 border-indigo bg-surface-2 px-3 py-2">
                  <span class="block text-[10px] font-semibold uppercase tracking-wider text-indigo/70">
                    {e.label}
                  </span>
                  <code class="mt-0.5 block font-mono text-sm leading-relaxed text-ink">
                    {e.expr}
                  </code>
                </div>
              ))}
            </div>

            <ul class="mt-4 flex flex-wrap gap-1.5">
              {a.params.map((p) => (
                <li class="rounded-md bg-indigo-soft px-2 py-1 font-mono text-xs text-indigo">{p}</li>
              ))}
            </ul>

            <p class="mt-auto pt-4 text-xs leading-relaxed text-soft">{a.nota}</p>
          </div>
        ))
      }
    </div>

    <div class="reveal mt-14 rounded-2xl border border-line bg-surface p-6 shadow-soft">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <h3 class="font-semibold">Comparativa de filtros sobre señal sintética</h3>
        <span class="rounded bg-surface-2 px-2 py-0.5 text-xs text-muted">
          Datos representativos — escala ilustrativa
        </span>
      </div>
      <canvas id="chart-smoothing" height="120"></canvas>
    </div>
  </div>
</section>

<script>
  import Chart from 'chart.js/auto';
  import { noisySignal, kalman1D, smooth } from '../lib/signals';

  // Tonos neutros que se leen en claro y oscuro (ejes, grilla, leyenda).
  Chart.defaults.color = '#94a3b8';
  Chart.defaults.borderColor = 'rgba(148,163,184,0.16)';

  const N = 90;
  const raw = noisySignal(N, 21);
  const labels = Array.from({ length: N }, (_, i) => i); // minutos
  const el = document.getElementById('chart-smoothing') as HTMLCanvasElement;

  function build() {
    new Chart(el, {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Señal original (ruidosa)', data: raw, borderColor: '#cbd5e1', borderWidth: 1, pointRadius: 0, tension: 0 },
          { label: 'Kalman', data: kalman1D(raw), borderColor: '#0ea5e9', borderWidth: 1.5, pointRadius: 0, tension: 0.2 },
          { label: 'Savitzky-Golay', data: smooth(raw, 4), borderColor: '#10b981', borderWidth: 1.5, pointRadius: 0, tension: 0.2 },
          { label: 'Whittaker (λ=10)', data: smooth(raw, 8), borderColor: '#4f46e5', borderWidth: 3, pointRadius: 0, tension: 0.3 },
        ],
      },
      options: {
        responsive: true,
        interaction: { mode: 'index', intersect: false },
        animation: { duration: 1800, easing: 'easeInOutQuart' },
        // dibuja cada filtro de forma escalonada
        animations: { y: { from: (ctx: any) => (ctx.chart.scales.y.getPixelForValue(20)) } },
        transitions: { show: { animation: { duration: 1800 } } },
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 14, usePointStyle: true } } },
        scales: {
          x: { title: { display: true, text: 'Tiempo (minutos)' }, ticks: { maxTicksLimit: 10 }, grid: { display: false } },
          y: { title: { display: true, text: 'Corriente (A)' } },
        },
      },
    });
  }

  // Arranca la animación cuando el chart entra en pantalla.
  const io = new IntersectionObserver((es) => {
    for (const e of es) if (e.isIntersecting) { build(); io.disconnect(); }
  }, { threshold: 0.3 });
  io.observe(el);
</script>
