---
const metrics = [
  { prefix: '', value: 2, suffix: '', label: 'Bloques universitarios monitoreados' },
  { prefix: '', value: 5, suffix: '', label: 'Parámetros eléctricos analizados' },
  { prefix: 'λ = ', value: 10, suffix: '', label: 'Parámetro óptimo del suavizador Whittaker' },
  { prefix: '', value: 168, suffix: ' h', label: 'Horizonte máximo de predicción (7 días)' },
];
---

<section class="relative overflow-hidden border-b border-line bg-canvas">
  <div class="graticule absolute inset-0"></div>

  <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-16 sm:pt-28">
    <!-- Barra de estado tipo instrumento -->
    <div class="reveal mono flex flex-wrap items-center gap-x-4 gap-y-2 text-[11px] uppercase tracking-widest text-muted">
      <span class="inline-flex items-center gap-1.5 text-signal">
        <span class="pulse-dot h-2 w-2 rounded-full bg-signal"></span> REC
      </span>
      <span aria-hidden="true" class="text-line">│</span>
      <span>CH1 · VOLTAGE</span>
      <span aria-hidden="true" class="text-line">│</span>
      <span>CECAR · ING. DE SISTEMAS</span>
      <span aria-hidden="true" class="text-line">│</span>
      <span>PROYECTO DE INVESTIGACIÓN</span>
    </div>

    <h1 class="reveal mt-6 max-w-4xl text-4xl font-bold leading-[1.02] tracking-tight text-ink sm:text-6xl">
      Sistema Inteligente de Monitoreo de
      <span class="text-signal glow">Parámetros Eléctricos</span>
    </h1>

    <p class="reveal mono mt-4 max-w-2xl text-sm uppercase tracking-wider text-muted">
      Corporación Universitaria del Caribe (CECAR)
    </p>

    <p class="reveal mt-6 max-w-3xl text-base leading-relaxed text-soft">
      Una plataforma que convierte la energía de los edificios universitarios en
      conocimiento. Sensores de alta precisión capturan el pulso eléctrico de cada bloque,
      un pipeline de filtrado limpia el ruido inherente a la medición y una red neuronal
      recurrente <strong class="font-semibold text-ink">aprende a predecir el consumo</strong>
      con días de anticipación. El objetivo: demostrar que un dato bien suavizado vale más
      que un dato crudo a la hora de anticipar la demanda energética.
    </p>

    <div class="reveal mt-8 flex flex-wrap gap-3 text-sm">
      <a href="#arquitectura" class="mono rounded-md bg-signal px-5 py-2.5 font-medium uppercase tracking-wide text-canvas shadow-soft transition hover:brightness-110">
        Explorar la arquitectura →
      </a>
      <a href="#suavizado" class="mono rounded-md border border-line bg-surface px-5 py-2.5 font-medium uppercase tracking-wide text-ink transition hover:border-signal hover:text-signal">
        Ver los algoritmos
      </a>
    </div>

    <!-- Pantalla del osciloscopio -->
    <div class="reveal scanline mt-12 overflow-hidden rounded-lg border border-line shadow-lift">
      <div class="mono flex items-center justify-between border-b border-line bg-surface px-4 py-2 text-[11px] uppercase tracking-wider text-muted">
        <span class="flex items-center gap-2">
          <span class="text-amber">RAW</span>
          <span aria-hidden="true">→</span>
          <span class="text-signal">SMOOTHED · WHITTAKER λ=10</span>
        </span>
        <span class="rounded border border-line px-2 py-0.5">SYNTHETIC · ILUSTRATIVA</span>
      </div>
      <div class="screen relative">
        <div class="graticule absolute inset-0"></div>
        <canvas id="hero-wave" class="relative block w-full" height="220"></canvas>
      </div>
    </div>

    <!-- Fila de readouts -->
    <dl class="mt-12 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-4" data-stagger>
      {
        metrics.map((m) => (
          <div class="reveal bg-surface p-5">
            <dt class="mono tnum text-3xl font-medium tracking-tight text-signal sm:text-4xl">
              <span
                data-count={m.value}
                data-prefix={m.prefix}
                data-suffix={m.suffix}
              >
                {m.prefix}0{m.suffix}
              </span>
            </dt>
            <dd class="mono mt-2 text-[11px] uppercase leading-relaxed tracking-wider text-muted">{m.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<script>
  import { noisySignal, smooth } from '../lib/signals';

  const canvas = document.getElementById('hero-wave') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const N = 160;
  const raw = noisySignal(N, 11);
  const clean = smooth(raw, 7);
  const min = Math.min(...raw) - 2;
  const max = Math.max(...raw) + 2;

  // Colores leídos del tema (CSS vars) — se actualizan al alternar tema.
  let css = { signal: '#34e29b', amber: '#f5b13f', graphite: '#3a4654', dark: true };
  function readTheme() {
    const s = getComputedStyle(document.documentElement);
    css = {
      signal: s.getPropertyValue('--color-signal').trim() || css.signal,
      amber: s.getPropertyValue('--color-amber').trim() || css.amber,
      graphite: s.getPropertyValue('--color-graphite').trim() || css.graphite,
      dark: document.documentElement.classList.contains('dark'),
    };
  }
  readTheme();
  window.addEventListener('themechange', readTheme);

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    canvas.width = canvas.clientWidth * dpr;
    canvas.height = 220 * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  function draw(series: number[], color: string, width: number, glow = 0) {
    const w = canvas.clientWidth;
    const h = 220;
    ctx.beginPath();
    series.forEach((v, i) => {
      const x = (i / (N - 1)) * w;
      const y = h - ((v - min) / (max - min)) * (h - 24) - 12;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.shadowBlur = glow;
    ctx.shadowColor = color;
    ctx.strokeStyle = color;
    ctx.lineWidth = width;
    ctx.lineJoin = 'round';
    ctx.stroke();
    ctx.shadowBlur = 0;
  }

  let t = 0; // 0 = cruda, 1 = suavizada (oscila)
  function frame() {
    const w = canvas.clientWidth;
    ctx.clearRect(0, 0, w, 220);
    // rastro tenue de la señal cruda (ámbar tenue)
    draw(raw, css.amber + '55', 1);
    const morphed = raw.map((v, i) => v + (clean[i] - v) * t);
    const clean50 = t > 0.5;
    const color = clean50 ? css.signal : css.amber;
    draw(morphed, color, 2.6, clean50 && css.dark ? 14 : 0);
    t += 0.006;
    if (t > 1) t = 0;
    requestAnimationFrame(frame);
  }
  frame();
</script>
