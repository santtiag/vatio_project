---
const metrics = [
  { prefix: '', value: 2, suffix: '', label: 'Bloques universitarios monitoreados' },
  { prefix: '', value: 5, suffix: '', label: 'Parámetros eléctricos analizados' },
  { prefix: 'λ = ', value: 10, suffix: '', label: 'Parámetro óptimo del suavizador Whittaker' },
  { prefix: '', value: 168, suffix: ' h', label: 'Horizonte máximo de predicción (7 días)' },
];
---

<section class="relative overflow-hidden border-b border-line bg-canvas">
  <div class="absolute inset-0 bg-grid"></div>
  <div class="blob -left-24 -top-24 h-80 w-80 bg-indigo-soft"></div>
  <div class="blob right-0 top-32 h-72 w-72" style="background:#dbeafe; animation-delay:-4s"></div>
  <div class="blob left-1/3 top-72 h-64 w-64" style="background:#ede9fe; animation-delay:-8s"></div>

  <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-16 sm:pt-28">
    <div class="reveal mb-4 inline-flex items-center gap-2 rounded-full border border-indigo/15 bg-surface/70 px-3 py-1 text-sm font-medium text-indigo backdrop-blur">
      <span class="pulse-dot h-2 w-2 rounded-full bg-indigo"></span>
      Proyecto de investigación · Ingeniería de Sistemas · CECAR
    </div>

    <h1 class="reveal max-w-4xl text-4xl font-semibold leading-[1.05] tracking-tight text-ink sm:text-6xl">
      Sistema Inteligente de Monitoreo de
      <span class="text-gradient animate-gradient">Parámetros Eléctricos</span>
    </h1>

    <p class="reveal mt-5 max-w-2xl text-lg text-muted">
      Corporación Universitaria del Caribe (CECAR) — Ingeniería de Sistemas
    </p>

    <p class="reveal mt-6 max-w-3xl text-base leading-relaxed text-soft">
      Una plataforma que convierte la energía de los edificios universitarios en
      conocimiento. Sensores de alta precisión capturan el pulso eléctrico de cada bloque,
      un pipeline de filtrado limpia el ruido inherente a la medición y una red neuronal
      recurrente <strong class="font-semibold text-ink">aprende a predecir el consumo</strong>
      con días de anticipación. El objetivo: demostrar que un dato bien suavizado vale más
      que un dato crudo a la hora de anticipar la demanda energética.
    </p>

    <div class="reveal mt-8 flex flex-wrap gap-3 text-sm">
      <a href="#arquitectura" class="rounded-full bg-indigo px-5 py-2.5 font-medium text-white shadow-soft transition hover:bg-indigo-700 hover:shadow-lift">
        Explorar la arquitectura
      </a>
      <a href="#suavizado" class="rounded-full border border-line bg-surface px-5 py-2.5 font-medium text-ink transition hover:border-indigo hover:text-indigo">
        Ver los algoritmos
      </a>
    </div>

    <div class="reveal mt-12 overflow-hidden rounded-2xl border border-line bg-surface shadow-lift">
      <div class="flex items-center justify-between border-b border-line px-4 py-2 text-xs text-muted">
        <span class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-slate-300"></span>
          Señal de corriente — ruidosa
          <span class="text-indigo">→</span>
          suavizada (Whittaker)
        </span>
        <span class="rounded bg-surface-2 px-2 py-0.5">Señal sintética · escala ilustrativa</span>
      </div>
      <canvas id="hero-wave" class="block w-full" height="220"></canvas>
    </div>

    <dl class="mt-12 grid grid-cols-2 gap-6 sm:grid-cols-4" data-stagger>
      {
        metrics.map((m) => (
          <div class="reveal card-lift rounded-xl border border-line bg-surface p-5 shadow-soft">
            <dt class="text-3xl font-semibold tracking-tight text-indigo sm:text-4xl">
              <span
                data-count={m.value}
                data-prefix={m.prefix}
                data-suffix={m.suffix}
              >
                {m.prefix}0{m.suffix}
              </span>
            </dt>
            <dd class="mt-2 text-sm text-muted">{m.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<script>
  import { noisySignal, smooth } from '../lib/signals';

  const canvas = document.getElementById('hero-wave') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const N = 160;
  const raw = noisySignal(N, 11);
  const clean = smooth(raw, 7);
  const min = Math.min(...raw) - 2;
  const max = Math.max(...raw) + 2;

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    canvas.width = canvas.clientWidth * dpr;
    canvas.height = 220 * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  function draw(series: number[], color: string, width: number, glow = 0) {
    const w = canvas.clientWidth;
    const h = 220;
    ctx.beginPath();
    series.forEach((v, i) => {
      const x = (i / (N - 1)) * w;
      const y = h - ((v - min) / (max - min)) * (h - 24) - 12;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.shadowBlur = glow;
    ctx.shadowColor = color;
    ctx.strokeStyle = color;
    ctx.lineWidth = width;
    ctx.lineJoin = 'round';
    ctx.stroke();
    ctx.shadowBlur = 0;
  }

  let t = 0; // 0 = ruidosa, 1 = suavizada (oscila)
  function frame() {
    const w = canvas.clientWidth;
    ctx.clearRect(0, 0, w, 220);
    // rastro tenue de la señal cruda
    draw(raw, 'rgba(148,163,184,0.35)', 1);
    const morphed = raw.map((v, i) => v + (clean[i] - v) * t);
    const indigo = t > 0.5;
    draw(morphed, indigo ? '#4f46e5' : '#94a3b8', 2.6, indigo ? 12 : 0);
    t += 0.006;
    if (t > 1) t = 0;
    requestAnimationFrame(frame);
  }
  frame();
</script>
